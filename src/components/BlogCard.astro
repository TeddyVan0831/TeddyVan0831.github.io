---
interface Props {
  title: string
  description: string
  date: string
  tags: string[]
  link: string
}

const { title, description, date, tags, link } = Astro.props

function formatDate(dateStr: string) {
  const date = new Date(dateStr)
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
}
---

<a href={link} class="block p-6 bg-slate-50 dark:bg-slate-800 rounded-xl card-hover border border-slate-100 dark:border-slate-700 group">
  <div class="text-sm text-slate-500 dark:text-slate-400 mb-2">
    {formatDate(date)}
  </div>
  <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
    {title}
  </h3>
  <p class="text-slate-600 dark:text-slate-300 text-sm mb-4 line-clamp-2">
    {description}
  </p>
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs rounded">
        {tag}
      </span>
    ))}
  </div>
</a>
