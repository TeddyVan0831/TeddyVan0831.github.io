---
interface Props {
  title: string
  description: string
  tech: string[]
  link: string
  stats?: { stars: number; forks: number }
}

const { title, description, tech, link, stats } = Astro.props
---

<a href={link} target={link.startsWith('http') ? '_blank' : undefined} rel={link.startsWith('http') ? 'noopener' : undefined} class="block overflow-hidden bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-500 border border-gray-100 group">
  <div class="h-32 bg-gradient-to-br from-slate-100 to-stone-200 relative flex items-center justify-center">
    <div class="w-16 h-16 bg-white/60 backdrop-blur rounded-2xl flex items-center justify-center text-3xl shadow-sm">
      📚
    </div>
    {stats && stats.stars > 0 && (
      <div class="absolute top-4 right-4 px-3 py-1 bg-white/90 backdrop-blur rounded-full text-sm font-medium text-slate-600">
        ⭐ {stats.stars}
      </div>
    )}
  </div>
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2 text-slate-700 group-hover:text-slate-900 transition-colors">
      {title}
    </h3>
    <p class="text-slate-400 mb-4 leading-relaxed line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {tech.slice(0, 4).map((t) => (
        <span class="px-3 py-1 bg-slate-100 text-slate-600 text-sm rounded-full">
          {t}
        </span>
      ))}
      {tech.length > 4 && (
        <span class="px-3 py-1 bg-slate-100 text-slate-500 text-sm rounded-full">
          +{tech.length - 4}
        </span>
      )}
    </div>
  </div>
</a>
