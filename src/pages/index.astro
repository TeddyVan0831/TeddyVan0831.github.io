---
import Layout from '../layouts/Layout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import BlogCard from '../components/BlogCard.astro'

// 项目数据
const projects = [
  {
    title: 'edu-kt-demo',
    description: '基于知识追踪与知识图谱的智能教育系统，支持多学科自适应学习路径推荐',
    tech: ['Python', 'PyTorch', 'FastAPI', 'Knowledge Graph', 'DKT/AKT'],
    link: 'https://github.com/TeddyVan0831/edu-kt-demo',
    stats: { stars: 128, forks: 34 }
  },
  {
    title: 'AI 教育研究系列',
    description: '涵盖知识追踪算法、知识图谱构建、教育大模型融合等前沿技术的深度研究',
    tech: ['LLM Fine-tuning', 'Knowledge Tracing', 'Federated Learning'],
    link: '/blogs',
    stats: { stars: 0, forks: 0 }
  }
]

// 博客数据
const blogs = [
  {
    title: '12.96 万亿 Token 碾压 3.03 万亿',
    description: '中国 AI 大模型连续五周超越美国，OpenRouter 数据深度解读',
    date: '2026-04-07',
    tags: ['AI', '大模型', '数据分析'],
    link: '#'
  },
  {
    title: '具身智能的"GPT-3 时刻"何时到来？',
    description: '2026 中关村论坛年会圆桌会议深度解析，五家百亿估值企业创始人观点汇总',
    date: '2026-03-30',
    tags: ['具身智能', '机器人', 'AI'],
    link: '#'
  },
  {
    title: 'TRAE SOLO 独立：字节跳动的 Agent 野心',
    description: '从 IDE 到完整生产力工具，TRAE SOLO 的产品战略深度分析',
    date: '2026-04-02',
    tags: ['AI Agent', '产品分析', '字节跳动'],
    link: '#'
  }
]

// 研究方向数据
const researchAreas = [
  { name: '知识追踪 (KT)', icon: '📊', desc: 'DKT/AKT/Deep-KT 等算法研究', accent: 'blue' },
  { name: '知识图谱 (KG)', icon: '🕸️', desc: '教育领域知识结构化与推理', accent: 'amber' },
  { name: '教育大模型', icon: '🤖', desc: 'LLM 微调与教育场景融合', accent: 'emerald' },
  { name: '联邦学习', icon: '🔒', desc: '隐私保护的分布式学习', accent: 'rose' }
]

const accentColors = {
  blue: { bg: 'bg-blue-50', text: 'text-blue-600', icon: 'group-hover:bg-blue-100' },
  amber: { bg: 'bg-amber-50', text: 'text-amber-600', icon: 'group-hover:bg-amber-100' },
  emerald: { bg: 'bg-emerald-50', text: 'text-emerald-600', icon: 'group-hover:bg-emerald-100' },
  rose: { bg: 'bg-rose-50', text: 'text-rose-600', icon: 'group-hover:bg-rose-100' }
}
---

<Layout title="范俊峰 | AI 教育技术研究者">
  <!-- Hero Section -->
  <section class="py-28 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 text-emerald-600 rounded-full text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-emerald-400 rounded-full"></span>
        欢迎访问我的学术主页
      </div>
      <h1 class="text-5xl md:text-6xl font-bold mb-6 text-slate-800">
        范俊峰
      </h1>
      <p class="text-2xl text-slate-500 mb-4">
        AI 教育技术研究者
      </p>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
        专注于知识追踪算法、知识图谱构建与教育大模型融合研究，探索 AI 在教育领域的创新应用
      </p>

      <!-- 统计数据 -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <div class="text-center">
          <div class="text-3xl font-bold text-slate-800">4+</div>
          <div class="text-sm text-slate-400 mt-1">年研究经验</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-slate-800">10+</div>
          <div class="text-sm text-slate-400 mt-1">研究项目</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-slate-800">5</div>
          <div class="text-sm text-slate-400 mt-1">核心研究方向</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-slate-800">∞</div>
          <div class="text-sm text-slate-400 mt-1">学习热情</div>
        </div>
      </div>

      <!-- CTA 按钮 -->
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#about" class="px-8 py-4 bg-slate-700 text-white rounded-full font-semibold shadow-lg shadow-slate-200 hover:shadow-xl hover:bg-slate-800 transform hover:-translate-y-1 transition-all duration-300">
          了解更多
        </a>
        <a href="/projects" class="px-8 py-4 bg-white text-slate-600 rounded-full font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 border border-slate-200 hover:border-slate-300">
          查看项目
        </a>
        <a href="https://github.com/TeddyVan0831" target="_blank" rel="noopener" class="px-8 py-4 bg-white text-slate-600 rounded-full font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 border border-slate-200 hover:border-slate-300">
          GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- 关于我 -->
  <section id="about" class="py-20 px-6 bg-white/50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4 text-slate-800">关于我</h2>
      <p class="text-slate-400 text-center mb-12">持续探索 AI 与教育的交叉领域</p>
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            我是一名专注于 <strong class="text-slate-800">AI 教育技术</strong> 的研究者，致力于将人工智能技术应用于教育领域，推动个性化学习的实现。
          </p>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            当前研究重点包括：基于深度学习的知识追踪算法、教育领域知识图谱构建、大语言模型在教育场景的微调与应用，以及隐私保护的联邦学习方案。
          </p>
          <p class="text-lg text-slate-600 leading-relaxed">
            我相信 AI 技术能够革新教育方式，让每个学习者都能获得适合自己的学习路径和指导。
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-6 text-slate-800">研究方向</h3>
          <div class="grid gap-4">
            {researchAreas.map((area) => {
              const colors = accentColors[area.accent as keyof typeof accentColors]
              return (
                <div class="p-5 bg-white rounded-2xl shadow-md hover:shadow-lg transform hover:-translate-y-1 transition-all duration-300 border border-gray-100 group">
                  <div class="flex items-center gap-4">
                    <div class={`w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-2xl transition-colors ${colors.icon}`}>
                      {area.icon}
                    </div>
                    <div>
                      <h4 class="font-semibold text-slate-700">{area.name}</h4>
                      <p class="text-sm text-slate-400">{area.desc}</p>
                    </div>
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 技术栈 -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 text-slate-800">技术栈</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { name: 'Python', accent: 'slate' },
          { name: 'PyTorch', accent: 'orange' },
          { name: 'FastAPI', accent: 'emerald' },
          { name: 'Transformers', accent: 'amber' },
          { name: 'Knowledge Graph', accent: 'sky' },
          { name: 'LLM Fine-tuning', accent: 'violet' },
          { name: 'Streamlit', accent: 'red' },
          { name: 'Git & GitHub', accent: 'slate' }
        ].map((tech) => (
          <div class="px-4 py-3 bg-slate-100 text-slate-600 rounded-xl text-center font-medium hover:bg-slate-200 transition-colors cursor-default">
            {tech.name}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 项目展示 -->
  <section class="py-20 px-6 bg-white/50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4 text-slate-800">代表性项目</h2>
      <p class="text-slate-400 text-center mb-12">从知识追踪到教育大模型的技术实践</p>
      <div class="grid md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/projects" class="inline-flex items-center gap-2 text-slate-600 font-medium hover:text-slate-800 transition-colors group">
          查看全部项目
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 最新博客 -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4 text-slate-800">最新文章</h2>
      <p class="text-slate-400 text-center mb-12">AI 行业洞察与技术思考</p>
      <div class="grid md:grid-cols-3 gap-6">
        {blogs.map((blog) => (
          <BlogCard {...blog} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/blogs" class="inline-flex items-center gap-2 text-slate-600 font-medium hover:text-slate-800 transition-colors group">
          阅读更多文章
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
