---
import Layout from '../layouts/Layout.astro'
import BlogCard from '../components/BlogCard.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog')
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

// 获取所有标签
const allTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags || []))]
const categories = ['全部', ...allTags]
---

<Layout title="博客 | 范俊峰" description="范俊峰的 AI 教育技术博客，包含行业洞察与技术思考">
    
    <!-- Hero -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl font-bold mb-4 text-slate-800">
          博客
        </h1>
        <p class="text-xl text-slate-500">
          AI 行业洞察与技术思考
        </p>
      </div>
    </section>

    <!-- 分类筛选 -->
    <section class="py-8 px-6 border-b border-gray-100 bg-white/50 sticky top-16 backdrop-blur-md z-40">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-wrap gap-2 justify-center">
          {categories.map((cat, index) => (
            <button class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${index === 0 ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}>
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- 文章列表 -->
    <section class="py-16 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedPosts.map((post) => (
            <BlogCard 
              title={post.data.title}
              description={post.data.description}
              date={post.data.date.toISOString().split('T')[0]}
              tags={post.data.tags || []}
              link={`/blog/${post.id}`}
            />
          ))}
        </div>
      </div>
    </section>
</Layout>
