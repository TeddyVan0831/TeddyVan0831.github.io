---
import Layout from '../layouts/Layout.astro'
---

<Layout title="页面未找到 | 范俊峰">
  <section class="min-h-[80vh] flex items-center justify-center px-6">
    <div class="text-center">
      <div class="text-8xl font-bold text-slate-200 dark:text-slate-700 mb-4">404</div>
      <h1 class="text-2xl font-bold text-slate-800 dark:text-white mb-4">页面未找到</h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8">抱歉，您访问的页面不存在或已被移除。</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 dark:bg-white text-white dark:text-slate-800 rounded-lg font-medium hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        返回首页
      </a>
    </div>
  </section>
</Layout>
