---
import Layout from '../layouts/Layout.astro'

const projects = [
  {
    title: 'edu-kt-demo',
    description: '基于知识追踪与知识图谱的智能教育系统，支持多学科自适应学习路径推荐',
    tech: ['Python', 'PyTorch', 'FastAPI', 'Knowledge Graph', 'DKT', 'AKT'],
    github: 'https://github.com/TeddyVan0831/edu-kt-demo',
    stats: { stars: 128, forks: 34 },
    highlights: [
      '数学知识图谱：110 节点 / 159 边（人教版 7-9 年级全覆盖）',
      '历史知识图谱：37 节点 / 43 边',
      'DKT 模型 AUC 0.7586（CPU 环境，ASSISTments 数据集）',
      'FastAPI 服务：5 个接口（health/answer/mastery/recommend/score）',
      'Streamlit UI：主观题文本输入 + LLM 自动评分 + 雷达图'
    ]
  },
  {
    title: 'AI 教育研究系列',
    description: '涵盖知识追踪算法、知识图谱构建、教育大模型融合等前沿技术的深度研究',
    tech: ['LLM Fine-tuning', 'Knowledge Tracing', 'Federated Learning', 'Knowledge Graph'],
    github: '#',
    stats: { stars: 0, forks: 0 },
    highlights: [
      '知识追踪算法研究：DKT → AKT → Deep-KT 演进分析',
      '教育领域知识图谱构建方法论',
      '大语言模型在教育场景的微调与应用',
      '隐私保护的联邦学习方案探索'
    ]
  }
]

const allTech = ['Python', 'PyTorch', 'FastAPI', 'Streamlit', 'Knowledge Graph', 'LLM', 'Transformer', 'DKT/AKT', 'TensorFlow', 'PyTorch Geometric']
---

<Layout title="项目 | 范俊峰" description="范俊峰的 AI 教育技术研究项目">
    
    <!-- Hero -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl font-bold mb-4 text-slate-800">
          研究项目
        </h1>
        <p class="text-xl text-slate-500">
          从知识追踪到教育大模型的持续探索
        </p>
      </div>
    </section>

    <!-- 项目列表 -->
    <section class="py-16 px-6">
      <div class="max-w-5xl mx-auto">
        {projects.map((project, index) => (
          <div class="mb-16">
            <div class="flex items-start gap-6">
              <div class="hidden md:block w-16 h-16 bg-slate-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="text-2xl font-bold text-slate-400">{String(index + 1).padStart(2, '0')}</span>
              </div>
              <div class="flex-1 bg-white rounded-2xl shadow-md p-8 border border-gray-100">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <h2 class="text-2xl font-bold text-slate-700 mb-2">
                      {project.title}
                    </h2>
                    <p class="text-slate-500">
                      {project.description}
                    </p>
                  </div>
                  {project.stats.stars > 0 && (
                    <div class="flex items-center gap-4 text-sm text-slate-400 ml-4">
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        {project.stats.stars}
                      </span>
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6z"/>
                        </svg>
                        {project.stats.forks}
                      </span>
                    </div>
                  )}
                </div>

                <!-- 技术栈 -->
                <div class="flex flex-wrap gap-2 mb-6">
                  {project.tech.map((t) => (
                    <span class="px-3 py-1 bg-slate-100 text-slate-600 text-sm rounded-full">
                      {t}
                    </span>
                  ))}
                </div>

                <!-- 项目亮点 -->
                <div class="bg-slate-50 rounded-xl p-6 border border-gray-100">
                  <h3 class="text-lg font-semibold text-slate-700 mb-4">项目亮点</h3>
                  <ul class="space-y-3">
                    {project.highlights.map((h) => (
                      <li class="flex items-start gap-3 text-slate-600">
                        <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        {h}
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- 链接 -->
                {project.github !== '#' && (
                  <div class="mt-6">
                    <a href={project.github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-slate-600 font-medium hover:text-slate-800 transition-colors group">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                      查看 GitHub 仓库
                      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 技术栈总览 -->
    <section class="py-16 px-6 bg-white/50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold text-center mb-8 text-slate-800">
          技术栈总览
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {allTech.map((tech) => (
            <span class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-full shadow-sm">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </section>
</Layout>
