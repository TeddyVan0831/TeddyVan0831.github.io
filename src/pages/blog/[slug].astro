---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = new Date(post.data.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Layout title={`${post.data.title} | 范俊峰`} description={post.data.description}>
  <article class="max-w-3xl mx-auto py-12 px-6">
    <!-- 返回链接 -->
    <a href="/blogs" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-600 mb-8 transition-colors text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      返回博客
    </a>

    <!-- 文章头 -->
    <header class="mb-10 pb-8 border-b border-slate-100">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-slate-400 text-sm">
        <time datetime={post.data.date.toISOString()}>
          <span class="inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {formattedDate}
          </span>
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-2.5 py-1 bg-slate-100 text-slate-500 rounded-full text-xs font-medium">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- 文章内容 -->
    <div class="blog-prose">
      <Content />
    </div>

    <!-- 底部导航 -->
    <footer class="mt-16 pt-8 border-t border-slate-100">
      <a href="/blogs" class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg transition-colors text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        返回博客列表
      </a>
    </footer>
  </article>
</Layout>
